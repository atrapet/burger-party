# Reverse-proxy snippet for nginx — drop into your existing server block.
# The Upgrade/Connection headers are REQUIRED for Socket.io's WebSocket transport;
# without them Socket.io silently falls back to slower HTTP long-polling.

server {
    listen 443 ssl;
    server_name burger.example.com;   # <-- your hostname

    # ssl_certificate / ssl_certificate_key managed by your existing setup (certbot, etc.)

    location / {
        proxy_pass http://127.0.0.1:3000;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket connections are long-lived; avoid premature timeouts.
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
